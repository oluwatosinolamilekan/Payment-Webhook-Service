# Application
NODE_ENV=development
PORT=3000
API_VERSION=v1

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=payment_webhooks
DB_USER=pay4x
DB_PASSWORD=your_secure_password
DB_POOL_MIN=2
DB_POOL_MAX=20

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Webhook Security
WEBHOOK_SIGNING_SECRET=whsec_your_signing_secret_here
WEBHOOK_TOLERANCE_SECONDS=300

# API Authentication
API_KEY_HEADER=X-API-Key
JWT_SECRET=your_jwt_secret_here

# Queue Configuration
QUEUE_CONCURRENCY=10
WEBHOOK_RETRY_ATTEMPTS=5
WEBHOOK_RETRY_DELAY=60000

# Payment Gateway Keys (examples)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
ADYEN_API_KEY=xxx
ADYEN_MERCHANT_ACCOUNT=xxx

# Monitoring
METRICS_ENABLED=true
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
